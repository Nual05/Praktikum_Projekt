<Window x:Class="Lagerverwaltungs.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lagerverwaltungs"
        mc:Ignorable="d"
        Title="MainWindow" Height="500" Width="1170"
        FontSize="14"
        Background="AliceBlue">
    <Window.DataContext>
        <local:ViewModell x:Name="vm"/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Margin="10">

            <TextBlock Text="Suchen: " Margin="5,7,5,5"/>
            <TextBox Height="20" Width="150" Margin="0,7,10,5"/>


            <Button Click="Neu_Click" Content="Neu" Margin="5" RenderTransformOrigin="24.132,11.85"/>
            <Button Content="Bearbeiten" Margin="5"/>
            <Button Content="Buchen" Margin="5"/>
            <Button Content="Löschen" Margin="5"/>

        </StackPanel>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="287*"/>
                <ColumnDefinition Width="113*"/>
            </Grid.ColumnDefinitions>
            <DataGrid ItemsSource="{Binding Table}"  AutoGenerateColumns="True" Grid.ColumnSpan="1" Margin="0,0,142,0"/>


            <TextBlock Text="Neuer Artikel erstellen" VerticalAlignment="Top" Grid.Column="1" Margin="0,0,-804,0" FontSize="20" FontStyle="Italic"/>
            <Label Content="ArtikelNummer" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,26,-703,0"/>
            <Label Content="Bezeichnung" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,56,-703,0"/>
            <Label Content="Kategorie" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,86,-703,0"/>
            <Label Content="Bestand" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,116,-703,0"/>
            <Label Content="Mindestbestand" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,146,-703,0"/>
            <Label Content="Einheit" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,176,-703,0"/>

            <TextBox Text="{Binding ArtikelNummer}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,31,42,0"/>
            <TextBox Text="{Binding Bezeichnung}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,61,42,0"/>
            <TextBox Text="{Binding Kategorie}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,91,42,0"/>
            <TextBox Text="{Binding Bestand}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,121,42,0"/>
            <TextBox Text="{Binding MindesBestand}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,151,42,0"/>
            <TextBox Text="{Binding Einheit}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="42,181,42,0"/>

            <TextBlock Text="Neue Buchung machen" VerticalAlignment="Top" Grid.Column="1" Margin="0,230,-804,0" FontSize="20" FontStyle="Italic"/>
            <Label Content="ArtikelNummer" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,260,-703,0"/>
            <Label Content="Datum" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,293,-703,0"/>
            <Label Content="Menge" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,329,-703,0"/>
            <Label Content="Typ" VerticalAlignment="Top" Grid.ColumnSpan="2" Margin="703,359,-703,0"/>

            <TextBox Text="{Binding Artikelnummervonbuchung}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="44,264,45,0" />
            <DatePicker SelectedDate="{Binding Datum, Mode=TwoWay}" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="44,294,45,0" />
            <TextBox Text="{Binding Menge}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="49,333,49,0" />
            <TextBox Text="{Binding Typ}" TextWrapping="Wrap" VerticalAlignment="Top" Width="227" Grid.Column="1" Margin="49,363,49,0" />

        </Grid>
    </Grid>
</Window>
